*.pt
*.pth
*.ckpt
*.safetensors
*.onnx
*.bin
*.joblib
*.pickle
*.pkl

# --- Python packaging & environments ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
