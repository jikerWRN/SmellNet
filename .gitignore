# --- Datasets & paper assets you host elsewhere (e.g. Hugging Face) ---
# Users must download these after cloning — they are NOT committed to Git.
data/
base_data/
ICLR_data/   # legacy folder name; use base_data/
gcms_processed/
gcms_data/
mixture_data/
text_data/

# Large / derived tables and embeddings (download from HF after clone)
*.npy
*.npz
*.parquet
full_gcms_dataframe.csv
processed_full_gcms_dataframe.csv
# Raw or duplicated exports from acquisition scripts
data_collection/*.csv
data_stats/

# --- Training / experiment outputs (regenerate locally) ---
logs/
runs/
checkpoints/
wandb/
mlruns/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.hypothesis/
.coverage
htmlcov/

