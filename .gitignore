.installed.cfg
*.egg
.venv/
venv/
ENV/
.env
.env.*
!.env.example

# Jupyter
.ipynb_checkpoints/

# --- Tools & editors (machine-local; remove from git if you already track them) ---
.idea/
.vscode/
*.swp
*.swo
*~

# --- OS junk ---
.DS_Store
._*
Thumbs.db
Desktop.ini

# --- Optional large vendor drops under Arduino (prefer submodule or doc link) ---
Arduino/**/data/*.zip

# --- Hugging Face / dataset tooling caches if stored inside the repo ---
.huggingface/
hf_cache/
datasets_cache/

# --- Misc scratch ---
tmp/
scratch/
*.log

# Root-level manuscript PDFs (often large); keep paper figures under analysis/ or data_stats/
/iclr*.pdf
/ICLR*.pdf
